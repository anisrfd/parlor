# ─────────────────────────────────────────────────────────────
# Parlor (Bengali) configuration
#
# Copy this to node-service/.env (or repo-root .env) and fill in the key.
# GOOGLE_API_KEY is optional: without it, Parlor falls back to a local Gemma
# model via Ollama (see below). Everything else has sensible defaults.
# ─────────────────────────────────────────────────────────────

# Free Gemma access via Google AI Studio — get a key at https://aistudio.google.com/apikey
# Leave empty to run fully local via Ollama instead.
GOOGLE_API_KEY=your-google-ai-studio-key-here

# Which Gemma model to use (must support image input for the camera feature).
# Options (as of 2026-07): gemma-4-31b-it (default), gemma-4-26b-a4b-it
# The gemma-3-* family was retired by Google and now returns 404.
# GEMMA_MODEL=gemma-4-31b-it

# ── Local fallback (used automatically when GOOGLE_API_KEY is empty) ──
# Pick the on-device engine with LOCAL_BACKEND: 'ollama' (default) or 'litert'.
# LOCAL_BACKEND=ollama
#
# Ollama backend (https://ollama.com) — install, then:  ollama pull gemma3
# OLLAMA_MODEL=gemma3
# OLLAMA_HOST=http://localhost:11434
#
# LiteRT-LM backend — Parlor's original on-device stack (Gemma-4 E2B .litertlm on
# Metal GPU; see artifacts/05-architecture-and-plan.md). Needs a LiteRT-LM HTTP shim
# exposing POST /generate. Then set LOCAL_BACKEND=litert.
# LITERT_MODEL=gemma-4-e2b-it
# LITERT_HOST=http://localhost:8110

# Bengali edge-tts voice. Options: bn-BD-NabanitaNeural (female, default),
# bn-BD-PradeepNeural (male), bn-IN-TanishaaNeural, bn-IN-BashkarNeural
# TTS_VOICE=bn-BD-NabanitaNeural

# Node glue service port (edge-tts + Gemma proxy)
# NODE_SERVICE_PORT=8100

# Python server → Node glue service URL (used by src/server.py)
# NODE_SERVICE_URL=http://localhost:8100

# Python server port
# PORT=8000
